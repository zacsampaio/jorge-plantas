# ============================================================
# COPIE este arquivo para .env e preencha com valores REAIS.
# O .env.example fica vazio de propósito — não é lido pelo Vite.
# ============================================================

# Supabase → Dashboard → Project Settings → API

# URL do projeto (ex.: https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Chave PÚBLICA do site — use UMA das opções:
# • Publishable (novo): sb_publishable_...
# • Anon legada (JWT): eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=

# Nome alternativo (mesmo valor da linha acima):
# VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Só para scripts locais (npm run upload:images) ──
# NUNCA coloque prefixo VITE_ aqui. Não vai para o navegador.
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
